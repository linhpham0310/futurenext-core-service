# .env.example - Template (SAFE TO COMMIT)

# --- Application ---
PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# --- Redis ---
REDIS_URL="redis://localhost:6380"
REDIS_PREFIX=stg:

# --- JWT ---
JWT_SECRET="YOUR_JWT_SECRET_HERE"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET="YOUR_REFRESH_TOKEN_SECRET_HERE"
REFRESH_TOKEN_EXPIRES_IN=7d

# --- URLs ---
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
FRONTEND_LOGIN_URL=http://localhost:3001/login

# --- App Logic ---
CURRENT_CONSENT_VERSION=vYYYY-MM-DD

# --- Throttler ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=10


# --- Email SMTP Configuration ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587 # or 465 or 2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password # NEVER commit real password here
EMAIL_FROM="Your App Name <noreply@yourverifieddomain.com>" # Use a verified domain for real ESPs
EMAIL_SECURE=true # Use 'true' for port 465 (SSL), 'false' otherwise (TLS/STARTTLS)
