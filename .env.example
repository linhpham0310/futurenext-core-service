# .env.example - Template for environment variables

# --- Application ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# --- Database (Supabase) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# --- JWT ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=900
REFRESH_TOKEN_SECRET=your_refresh_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# --- Email SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="FutureNext Dev <no-reply@dev.futurenext.ai>"
EMAIL_SECURE=false

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Redis ---
REDIS_URL=rediss://default:your_password@your-redis-host:6379
REDIS_PREFIX=stg:

# --- App Logic ---
CURRENT_CONSENT_VERSION=v2025-10-26-sprint0

# Login Attempts
LOGIN_FAILURE_LIMIT=10
LOGIN_LOCKOUT_DURATION=15m

# Email Verification
EMAIL_VERIFY_MAX_ATTEMPTS=5

# --- URLs ---
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
FRONTEND_LOGIN_URL=http://localhost:3001/login

# --- Throttler ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
