generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema",  "postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  
  schemas  = ["course_mgmt", "lx", "public"]
  //extensions = [uuid_ossp, vector] 
  directUrl = env("DIRECT_URL")  
}


enum CourseStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  REJECTED
  ARCHIVED

  @@schema("course_mgmt")
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ
  LAB

  @@schema("course_mgmt")
}

// ==================== course_mgmt ====================


model Course {
  id           String       @id @default(uuid())
  instructorId String
  lessons      Lesson[]
  title        String       @db.VarChar(255)
  slug         String       @unique
  description  String?      @db.Text
  thumbnailUrl String?
  price        Decimal      @default(0.0) @db.Decimal(12, 2)
  status       CourseStatus @default(DRAFT)
  outcomes     Json?
  aiMetadata   Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sections          Section[]
  reviewLogs        CourseReviewLog[]
  curriculumMapping CurriculumMapping[]
  purchases         Purchase[]
  favorites         Favorite[]
  reviews           Review[]
  certificates      Certificate[]
  announcements     Announcement[]

  @@index([instructorId])
  @@index([status])
  @@schema("course_mgmt")
  @@map("courses")
}

model Section {
  id         String @id @default(uuid())
  courseId   String
  title      String @db.VarChar(255)
  orderIndex Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@schema("course_mgmt")
  @@map("sections")
}

model Lesson {
  id            String     @id @default(uuid())
  sectionId     String
  courseId      String
  title         String     @db.VarChar(255)
  slug          String
  type          LessonType @default(ARTICLE)
  content       String?    @db.Text
  duration      Int?       @default(0)
  orderIndex    Int        @default(0)
  isFreePreview Boolean    @default(false)
  aiMetadata    Json       @default("[]")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt


  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)


  @@index([sectionId])
  @@schema("course_mgmt")
  @@map("lessons")
}

model CurriculumMapping {
  id            String @id @default(uuid())
  courseId      String
  keyConcept    String
  taxonomyLevel Int    @default(1)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@schema("course_mgmt")
  @@map("curriculum_mappings")
}

model CourseReviewLog {
  id        String       @id @default(uuid())
  courseId  String
  adminId   String
  action    CourseStatus
  reason    String?      @db.Text
  createdAt DateTime     @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@schema("course_mgmt")
  @@map("course_review_logs")
}

// ---------------------------------------------------------
// MODULE: LEARNING EXPERIENCE (LX) - SPRINT 1
// TASK: LX-BE-1.1
// ---------------------------------------------------------

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED

  @@schema("lx")
}

model LearningProgress {
  id           String         @id @default(uuid())

  userId       String
  courseId     String
  lessonId     String

  status       ProgressStatus @default(NOT_STARTED)

  lastPosition Int            @default(0)

  score        Decimal?       @db.Decimal(5, 2)

  metadata     Json?          @default("{}")

  completedAt  DateTime?

  updatedAt    DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@schema("lx")
  @@map("lx_learning_progress")
}

model AIInteraction {
  id              String   @id @default(uuid())

  userId          String   @map("user_id")
  lessonId        String   @map("lesson_id")
  
  interactionType String   @map("interaction_type") @db.VarChar(20)

  prompt          String   @db.Text

  response        String   @db.Text

  contextSnapshot Json?    @map("context_snapshot") @default("{}")
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId, lessonId])
  @@schema("lx")

  @@map("lx_ai_interactions")
}

model LxLessonContext {
  id           String   @id @default(uuid())
  lessonId     String   @map("lesson_id")

  chunkIndex   Int      @map("chunk_index")

  contentChunk String   @map("content_chunk") @db.Text

  metadata     Json?    @default("{}")

  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([lessonId, chunkIndex])

  @@index([lessonId])
  @@schema("lx")
  @@map("lx_lesson_contexts")
}

// ==================== public schema ====================

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  courseId  String

  amount      Decimal  @db.Decimal(12,2)
  status      String   @default("COMPLETED") 
  purchasedAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)


  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@schema("lx")
  @@map("purchases")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@schema("public")
  @@map("favorites")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@schema("public")
  @@map("reviews")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String   @db.Text
  description String   @db.Text
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@schema("public")
  @@map("notifications")
}

model Certificate {
  id             String   @id @default(uuid())
  userId         String
  courseId       String
  studentName    String   @db.VarChar(255)
  courseTitle    String   @db.VarChar(255)
  certificateUrl String   @db.Text
  issuedAt       DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@schema("public")
  @@map("certificates")
}

model Announcement {
  id          String   @id @default(uuid())
  courseId    String
  teacherId   String
  title       String   @db.VarChar(255)
  content     String   @db.Text
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@schema("public")
  @@map("announcements")
}

enum ExamType {
  MCQ
  ESSAY
  MIXED
  @@schema("public")
}

model Exam {
  id            String     @id @default(uuid())
  teacherId     String
  courseId      String 
  title         String     @db.Text
  topic         String?    @db.Text
  type          ExamType   @default(MCQ)
  duration      Int        @default(60)
  isPublished   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  questions   Question[]
  results     ExamResult[]

  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)


  @@index([teacherId])
  @@index([courseId])
  @@schema("public")
  @@map("exams")
}

enum ExamResultStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  @@schema("public")
}

model ExamResult {
  id             String           @id @default(uuid())
  examId         String
  userId         String
  score          Decimal?         @db.Decimal(5, 2)
  totalQuestions Int
  answers        Json             @default("{}")
  status         ExamResultStatus @default(NOT_STARTED)
  submittedAt    DateTime         @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
  @@index([userId])
  @@schema("public")
  @@map("exam_results")
}

model PaymentSetting {
  id            String   @id @default(uuid())
  userId        String   @unique
  bankName      String?  @db.VarChar(100)
  bankAccount   String?  @db.VarChar(50)
  accountHolder String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@schema("public")
  @@map("payment_settings")
}

model RevenueTransaction {
  id          String   @id @default(uuid())
  userId      String   
  teacherId   String  
  courseId    String
  amount      Decimal  @db.Decimal(12,2)
  type        String   
  status      String   
  createdAt   DateTime @default(now())

  @@index([teacherId])
  @@index([userId])
  @@schema("public")
  @@map("revenue_transactions")
}

enum QuestionType {
  MCQ
  ESSAY
  @@schema("public")
}

model Question {
  id            String       @id @default(uuid())
  examId        String
  text          String       @db.Text
  type          QuestionType @default(MCQ)
  options       Json?                          
  correctAnswer String?      @db.Text
  explanation   String?      @db.Text
  orderIndex    Int          @default(0)

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@schema("public")
  @@map("questions")
}

enum TransactionType {
  PURCHASE
  REFUND
  @@schema("public")
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
  @@schema("public")
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  courseId  String?
  amount    Decimal           @db.Decimal(12, 2)
  type      TransactionType   @default(PURCHASE)
  status    TransactionStatus @default(SUCCESS)
  createdAt DateTime          @default(now())

  @@index([userId])
  @@schema("public")
  @@map("transactions")
}


