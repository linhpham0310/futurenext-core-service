generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema",  "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  
  schemas  = ["course_mgmt", "lx"]
  extensions = [uuid_ossp, vector] 
}

enum CourseStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  REJECTED
  ARCHIVED

  @@schema("course_mgmt")
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ

  @@schema("course_mgmt")
}

model Course {
  id           String       @id @default(uuid())
  instructorId String
  title        String       @db.VarChar(255)
  slug         String       @unique
  description  String?      @db.Text
  thumbnailUrl String?
  price        Decimal      @default(0.0) @db.Decimal(12, 2)
  status       CourseStatus @default(DRAFT)
  outcomes     Json?
  aiMetadata   Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sections          Section[]
  reviewLogs        CourseReviewLog[]
  curriculumMapping CurriculumMapping[]

  @@index([instructorId])
  @@index([status])
  @@schema("course_mgmt")
  @@map("courses")
}

model Section {
  id         String @id @default(uuid())
  courseId   String
  title      String @db.VarChar(255)
  orderIndex Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@schema("course_mgmt")
  @@map("sections")
}

model Lesson {
  id            String     @id @default(uuid())
  sectionId     String
  title         String     @db.VarChar(255)
  slug          String
  type          LessonType @default(VIDEO)
  content       String?    @db.Text
  duration      Int?       @default(0)
  orderIndex    Int        @default(0)
  isFreePreview Boolean    @default(false)

  // TASK S4-CM-05: Thêm cột metadata cho AI (JSONB)
  aiMetadata Json @default("[]")

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@schema("course_mgmt")
  @@map("lessons")
}

model CurriculumMapping {
  id            String @id @default(uuid())
  courseId      String
  keyConcept    String
  taxonomyLevel Int    @default(1)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@schema("course_mgmt")
  @@map("curriculum_mappings")
}

model CourseReviewLog {
  id        String       @id @default(uuid())
  courseId  String
  adminId   String
  action    CourseStatus
  reason    String?      @db.Text
  createdAt DateTime     @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@schema("course_mgmt")
  @@map("course_review_logs")
}

// ---------------------------------------------------------
// MODULE: LEARNING EXPERIENCE (LX) - SPRINT 1
// TASK: LX-BE-1.1
// ---------------------------------------------------------

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED

  @@schema("lx")
}

model LearningProgress {
  id           String         @id @default(uuid())

  userId       String
  courseId     String
  lessonId     String

  status       ProgressStatus @default(NOT_STARTED)

  // Giây video hoặc vị trí code
  lastPosition Int            @default(0)

  // Quiz/Lab score
  score        Decimal?       @db.Decimal(5, 2)

  // Metadata linh hoạt
  metadata     Json?          @default("{}")

  completedAt  DateTime?

  updatedAt    DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@schema("lx")
  @@map("lx_learning_progress")
}

model AIInteraction {
  id              String   @id @default(uuid())

  userId          String   @map("user_id")
  lessonId        String   @map("lesson_id")
  
  // Loại tương tác: 'CHAT' (AI TA) hoặc 'LAB_COACH' (AI Lab) (LLD Page 2)
  interactionType String   @map("interaction_type") @db.VarChar(20)

  // Câu hỏi đầu vào của học viên
  prompt          String   @db.Text

  // Phản hồi trả về từ hệ thống AI (FastAPI Adapter)
  response        String   @db.Text

  // JSONB snapshot lưu nội dung bài học tại thời điểm hỏi để RAG ổn định (LLD Page 2)
  contextSnapshot Json?    @map("context_snapshot") @default("{}")
  
  createdAt       DateTime @default(now()) @map("created_at")

  // Thiết lập các Index tăng tốc truy vấn lịch sử cho học viên (LLD Page 1)
  @@index([userId, lessonId])
  @@schema("lx")

  // Map chính xác tên bảng vật lý trong PostgreSQL
  @@map("lx_ai_interactions")
}

model LxLessonContext {
  id           String   @id @default(uuid())
  lessonId     String   @map("lesson_id")

  // Thứ tự của đoạn văn bản trong bài học (0, 1, 2...) giúp tái tạo lại văn bản khi cần
  chunkIndex   Int      @map("chunk_index")

  // Nội dung thô của phân đoạn kiến thức (Paragraph/Chunk) dùng để feed vào Prompt AI
  contentChunk String   @map("content_chunk") @db.Text

  // Lưu trữ các metadata bổ trợ: từ khóa chính, thực thể (entities), hoặc vector id
  metadata     Json?    @default("{}")

  createdAt    DateTime @default(now()) @map("created_at")

  // Ràng buộc đảm bảo không bị trùng lặp vị trí phân đoạn của một bài học
  @@unique([lessonId, chunkIndex])

  // Tối ưu hóa tốc độ truy vấn tìm kiếm Knowledge theo bài học
  @@index([lessonId])
  @@schema("lx")
  @@map("lx_lesson_contexts")
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@schema("lx")
  @@map("lx_purchases")
}
